{
  "name": "ccdiary-web",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "description": "Cloudflare-hosted archive UI for CCDiary",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "wrangler dev",
    "deploy": "astro build && wrangler deploy",
    "astro": "astro",
    "db:apply:local": "wrangler d1 execute ccdiary --local --file=./schema.sql",
    "db:apply:remote": "wrangler d1 execute ccdiary --remote --file=./schema.sql",
    "db:console:local": "wrangler d1 execute ccdiary --local --command",
    "db:console:remote": "wrangler d1 execute ccdiary --remote --command",
    "typecheck": "astro check"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.2.1",
    "@astrojs/react": "^5.0.4",
    "@radix-ui/react-slot": "^1.1.2",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.4",
    "astro": "^6.1.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "marked": "^18.0.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "shiki": "^4.0.2",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.4",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@cloudflare/workers-types": "^4.20260425.1",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "typescript": "^5.7.3",
    "wrangler": "^4.85.0"
  }
}
